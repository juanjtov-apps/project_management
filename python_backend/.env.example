# Proesphere Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# DATABASE CONNECTIONS
# =============================================================================
# Development database (Neon PostgreSQL)
DATABASE_URL_DEV=postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require

# Production database (Neon PostgreSQL)
DATABASE_URL_PROD=postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require

# Fallback/legacy database URL (optional)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# =============================================================================
# SESSION MANAGEMENT
# =============================================================================
# Session encryption secret - generate with: openssl rand -hex 32
SESSION_SECRET=your-64-character-hex-string-here

# =============================================================================
# ENVIRONMENT
# =============================================================================
# Set to "development" or "production"
NODE_ENV=development

# =============================================================================
# GOOGLE CLOUD STORAGE (optional)
# =============================================================================
# GCS bucket for file uploads
GCS_BUCKET_ID=your-bucket-name

# Path to GCP service account credentials JSON
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# =============================================================================
# SSL CERTIFICATES (for Cloud SQL - legacy, optional)
# =============================================================================
# DB_SSL_DIR=/path/to/certs
# DB_SSL_ROOT_CERT=/path/to/server-ca.pem
# DB_SSL_CERT=/path/to/client-cert.pem
# DB_SSL_KEY=/path/to/client-key.pem

# =============================================================================
# DATABASE BACKUP
# =============================================================================
# Directory for storing production database backups
DB_BACKUP_DIR=/path/to/backup/directory

# =============================================================================
# AGENT AI CONFIGURATION
# =============================================================================
# LLM Provider (currently supports: openrouter)
AGENT_LLM_PROVIDER=openrouter

# OpenRouter API Key - get from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# Legacy 2-tier model config (used when AGENT_GATEKEEPER_ENABLED=false)
OPENROUTER_MODEL_STANDARD=google/gemini-1.5-flash
OPENROUTER_MODEL_COMPLEX=google/gemini-1.5-pro

# 3-Tier Router-Worker Model Configuration
# Gatekeeper - fast/cheap intent classification (Gemini Flash)
OPENROUTER_MODEL_GATEKEEPER=google/gemini-2.0-flash-001
# Specialist - handles simple queries like status lookups (~70% of traffic)
OPENROUTER_MODEL_SPECIALIST=openai/gpt-4o-mini
# Planner - complex multi-step operations like stage planning (~30% of traffic)
OPENROUTER_MODEL_PLANNER=anthropic/claude-sonnet-4
# Gatekeeper timeout in seconds (falls back to specialist on timeout)
AGENT_GATEKEEPER_TIMEOUT=3.0
# Set to "false" to disable gatekeeper and use legacy heuristic routing
AGENT_GATEKEEPER_ENABLED=true

# Maximum tool calls per conversation turn
AGENT_MAX_TOOL_CALLS=15

# Confirmation timeout for destructive operations (minutes)
AGENT_CONFIRMATION_TIMEOUT_MINUTES=30
