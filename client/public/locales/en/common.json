  "tutorial.staff.briefingTitle": "Morning Briefing",
  "tutorial.staff.briefingContent": "Your day starts here — overdue tasks, at-risk projects, and key updates at a glance. Example: Tap the 'overdue tasks' chip and Proe will list them instantly.",
  "tutorial.staff.chatTitle": "Talk to Proe",
  "tutorial.staff.chatContent": "Your AI assistant for everything. Try asking: 'What's overdue on Elm St?' → Proe shows a summary. 'Create a task for drywall install' → Proe creates it and asks you to confirm.",
  "tutorial.staff.inputTitle": "Chat Input",
  "tutorial.staff.inputContent": "Type here and press Enter to send. Example: Type 'Show project status' and hit Enter — Proe replies with progress, budget, and next steps. Use Shift+Enter for a new line.",
  "tutorial.staff.jobsTitle": "Active Projects",
  "tutorial.staff.jobsContent": "All your projects at a glance — progress bars, due dates, and AI health scores. Try it: Tap any project card, then ask Proe 'What needs attention here?'",

  "tutorial.sub.tasksTitle": "Your Tasks",
  "tutorial.sub.tasksContent": "All assigned tasks with priority, due date, and status. Example: Tap 'Start' on a task to begin work. When finished, tap 'Submit for Review' — your project manager gets notified.",
  "tutorial.sub.scheduleTitle": "Schedule",
  "tutorial.sub.scheduleContent": "See all work grouped by status. Tip: Red items are overdue — complete those first! Green items are on track.",
  "tutorial.sub.paymentsTitle": "Payments",
  "tutorial.sub.paymentsContent": "Track your contract value, milestones, and earnings. Example: You'll see 'Foundation Complete — $5,000 — Paid' so you always know where you stand.",
